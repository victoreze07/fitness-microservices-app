aws_region   = "us-east-1"
project_name = "fitness"

# Leave null to let AWS choose its default supported EKS version.
cluster_version = null

# Keep real IAM ARNs in terraform.tfvars only. Do not commit account-specific values.
# Example:
# cluster_admin_principal_arn = "arn:aws:iam::123456789012:user/terraform-user"
cluster_admin_principal_arn  = ""
cluster_admin_principal_arns = []
cluster_admin_access_policy_arn = "arn:aws:eks::aws:cluster-access-policy/AmazonEKSClusterAdminPolicy"

node_instance_types = ["t3.medium"]
node_desired_size   = 1
node_min_size       = 1
node_max_size       = 2
node_disk_size      = 20

install_argocd       = true
argocd_namespace     = "argocd"
argocd_chart_version = "7.7.11"

tags = {
  Environment = "dev"
}
